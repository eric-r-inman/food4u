# Before adding things like .DS_Store, ignores for your editors, etc, consider
# instead to use a global git ignore. This keeps the ignores here clean, and
# specific to this project - not your text editor, OS, or other tooling.
#
# Attempts to ignore files specific to your configuration will be rejected.
#
# Please justify all ignore entries with comments.

# Ignore cargo generated build artifacts.
target/

# Elm build cache.
frontend/elm-stuff/

# Compiled Elm bundle (generated by elm-make; not checked in).
frontend/public/elm.js

# Persisted food model written at runtime by `just dev` (the embedded
# default in crates/server/src/seed/ is the checked-in source of truth).
/food4u-model.json

# The relational store written at runtime by `just dev`, plus SQLite's
# write-ahead-log sidecar files.
/food4u.db
/food4u.db-wal
/food4u.db-shm

# The relational store written at runtime by `just login-demo`, holding the
# demo's per-account data, plus its write-ahead-log sidecar files.
/login-demo.db
/login-demo.db-wal
/login-demo.db-shm

# Claude Code project config (Stop hook, compliance subagent, shared settings)
# is part of the project and must be checked in.  A user-global or system-wide
# ignore (e.g. /etc/gitignore) often excludes .claude/ wholesale; re-include
# it.  Personal overrides go in .claude/settings.local.json, which Claude Code
# itself treats as the local-only file — that one stays ignored below.
!.claude/
.claude/settings.local.json